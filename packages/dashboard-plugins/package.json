  "repository": "https://github.com/eclipse-che/che-dashboard",
  "license": "EPL-2.0",
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "yarn clean && tsc -b",
    "build:dev": "yarn build",
    "watch": "yarn build && tsc -w",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "format:check": "yarn prettier --config .prettierrc --check src/",
    "format:fix": "yarn prettier --config .prettierrc --write src/",
    "lint:check": "tsc --noEmit && eslint '*/**/*.{js,ts,tsx}'",
    "lint:fix": "tsc --noEmit && eslint '*/**/*.{js,ts,tsx}' --fix",
    "test": "jest",
    "test:watch": "yarn test --watch"
  },
  "dependencies": {
    "@devfile/api": "2.3.0-1757407014",
    "@eclipse-che/common": "7.117.0-next",
    "@kubernetes/client-node": "^1.3.0",
    "@reduxjs/toolkit": "^2.2.7",
    "axios": "^1.15.2",
    "fastify": "^5.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-notice": "^0.9.10",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.1.6"
  }
}
