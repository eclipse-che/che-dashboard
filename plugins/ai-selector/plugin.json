{
  "id": "ai-selector",
  "name": "AI Selector Widget",
  "version": "1.0.0",
  "description": "Allows users to select and inject AI coding tools into workspaces",
  "enabled": true,
  "license": "EPL-2.0",
  "frontend": {
    "entry": "frontend/plugin.ts",
    "reducerKey": "aiConfig"
  },
  "backend": {
    "routes": [
      "backend/routes/aiConfig.ts",
      "backend/routes/aiRegistry.ts"
    ],
    "services": [
      "backend/services/aiProviderKeyApi.ts",
      "backend/services/aiRegistryApi.ts"
    ]
  }
}
